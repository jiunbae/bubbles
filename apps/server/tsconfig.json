{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["bun"],
    "paths": {
      "@bubbles/shared": ["../../packages/shared/src"],
      "@bubbles/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
